{
  "name": "reBiz-util-access",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/reBiz/util-access/src",
  "projectType": "library",
  "tags": ["type:util"],
  "targets": {
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test-full": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          {
            "command": "nx generate-prisma reBiz",
            "forwardAllArgs": false
          },
          "nx test reBiz-util-access"
        ],
        "options": {
          "cwd": "apps/reBiz"
        },
        "parallel": false
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/reBiz/util-access/jest.config.ts"
      }
    }
  }
}
