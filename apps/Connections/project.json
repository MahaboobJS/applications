{
  "name": "@ruyyaan-solutions/Connections",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "Connections/src",
  "projectType": "application",
  "tags": ["npm:private"],
  "targets": {
    "build": {
      "executor": "@nx/next:build",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "Connections/.next"
      },
      "configurations": {
        "development": {
          "outputPath": "Connections/.next"
        },
        "production": {}
      }
    },
    "serve": {
      "executor": "@nx/next:server",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "@ruyyaan-solutions/Connections:build",
        "dev": true
      },
      "configurations": {
        "development": {
          "buildTarget": "@ruyyaan-solutions/Connections:build:development",
          "dev": true
        },
        "production": {
          "buildTarget": "@ruyyaan-solutions/Connections:build:production",
          "dev": false
        }
      }
    },
    "export": {
      "executor": "@nx/next:export",
      "options": {
        "buildTarget": "@ruyyaan-solutions/Connections:build:production"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "Connections/jest.config.ts",
        "passWithNoTests": true
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    }
  }
}

