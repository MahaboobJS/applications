NEXTAUTH_SECRET=dev-secret-key-change-in-production

# Optional: Google OAuth (uncomment if needed)
# REBIZ_APP_AUTH_GOOGLE_ID=your-google-client-id
# REBIZ_APP_AUTH_GOOGLE_SECRET=your-google-client-secret

# Development Settings
NODE_ENV=development


# auth stuff
NEXTAUTH_URL=http://localhost:4200/api/v1/auth
NEXT_PUBLIC_NEXTAUTH_BASEPATH=/api/v1/auth
NEXT_PUBLIC_ENABLE_E2E=true
MONGODB_URI=mongodb://127.0.0.1:27017/rebiz
