{
  "name": "@ruyyaan-solutions/source",
  "version": "0.0.0",
  "license": "MIT",
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "nx lint --fix",
      "nx format:write"
    ],
    "*.{json,md,yml,yaml}": [
      "nx format:write"
    ]
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "scripts": {
    "prepare": "husky install",
    "pre-commit": "bash scripts/pre-commit.sh",
    "commit": "cz",
    "commit:retry": "cz --retry",
    "lint": "nx run-many --target=lint --all",
    "lint:fix": "nx run-many --target=lint --all --fix",
    "lint:apps": "nx run-many --target=lint --projects=rebiz",
    "lint:apps:fix": "nx run-many --target=lint --projects=rebiz --fix",
    "lint:libs": "nx run-many --target=lint --projects=shared-ui",
    "lint:libs:fix": "nx run-many --target=lint --projects=shared-ui --fix",
    "format": "nx format:write",
    "format:check": "nx format:check",
    "format:apps": "nx format:write --projects=rebiz",
    "format:libs": "nx format:write --projects=shared-ui",
    "type-check": "nx run-many --target=typecheck --all",
    "type-check:apps": "nx run-many --target=typecheck --projects=rebiz",
    "clean": "nx reset && nx run-many --target=clean --all",
    "test": "nx run-many --target=test --all",
    "test:watch": "nx run-many --target=test --all --watch",
    "test:coverage": "nx run-many --target=test --all --coverage",
    "build": "nx run-many --target=build --all",
    "build:apps": "nx run-many --target=build --projects=rebiz",
    "dev": "nx serve rebiz",
    "start": "nx serve rebiz --configuration=production",
    "check": "npm run format:check && npm run lint && npm run type-check",
    "check:fix": "npm run format && npm run lint:fix",
    "check:all": "npm run check && npm run test",
    "check:all:fix": "npm run check:fix && npm run test",
    "affected:build": "nx affected --target=build",
    "affected:test": "nx affected --target=test",
    "affected:lint": "nx affected --target=lint",
    "affected:type-check": "nx affected --target=typecheck",
    "graph": "nx graph",
    "dep-graph": "nx dep-graph",
    "show-projects": "nx show projects",
    "show-targets": "nx show targets",
    "migrate": "nx migrate latest",
    "reset": "nx reset"
  },
  "private": true,
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.2.0",
    "@mui/lab": "^7.0.0-alpha.170",
    "@mui/material": "^7.3.2",
    "@mui/x-date-pickers": "^8.9.0",
    "@mui/x-tree-view": "^8.12.0",
    "@next-auth/mongodb-adapter": "^1.1.3",
    "@tanstack/react-query": "^5.83.0",
    "@tanstack/react-query-devtools": "^5.83.0",
    "holy-loader": "^2.3.13",
    "lodash": "^4.17.21",
    "luxon": "^3.7.1",
    "mongodb": "^6.20.0",
    "next": "~15.2.4",
    "next-auth": "^4.24.11",
    "notistack": "^3.0.2",
    "react": "~18.3.1",
    "react-dom": "~18.3.1",
    "react-error-boundary": "^4.0.0",
    "react-hook-form": "^7.63.0",
    "react-is": "19.0.0",
    "react-router-dom": "^7.9.3",
    "react-spinners": "^0.17.0",
    "styled-components": "5.3.6"
  },
  "devDependencies": {
    "@babel/core": "^7.14.5",
    "@babel/preset-react": "^7.14.5",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.8.0",
    "@nx/cypress": "21.2.3",
    "@nx/eslint": "21.2.3",
    "@nx/eslint-plugin": "21.2.3",
    "@nx/jest": "21.2.3",
    "@nx/js": "21.2.3",
    "@nx/next": "^21.2.3",
    "@nx/react": "21.2.3",
    "@nx/workspace": "21.2.3",
    "@swc-node/register": "~1.9.1",
    "@swc/core": "~1.5.7",
    "@swc/helpers": "~0.5.11",
    "@swc/plugin-styled-components": "^1.5.67",
    "@types/jest": "^29.5.12",
    "@types/lodash": "^4.14.0",
    "@types/node": "^20.0.0",
    "@types/react": "~18.3.12",
    "@types/react-dom": "18.3.0",
    "@types/react-is": "19.0.0",
    "@types/styled-components": "5.1.26",
    "babel-plugin-styled-components": "1.10.7",
    "commitizen": "^4.3.1",
    "cypress": "^14.2.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-cypress": "^3.5.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.1",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^16.1.2",
    "nx": "21.2.3",
    "prettier": "^2.6.2",
    "react-test-renderer": "~18.3.1",
    "tslib": "^2.3.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.29.0"
  },
  "workspaces": [
    "apps/*",
    "libs/*"
  ]
}
