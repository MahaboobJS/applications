{
  "name": "@ruyyaan-solutions/source",
  "version": "0.0.0",
  "license": "MIT",
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "nx lint --fix",
      "nx format:write"
    ],
    "*.{json,md,yml,yaml}": [
      "nx format:write"
    ]
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "scripts": {
    "prepare": "husky install",
    "pre-commit": "bash scripts/pre-commit.sh",
    "commit": "cz",
    "commit:retry": "cz --retry",
    "lint": "nx run-many --target=lint --all",
    "lint:fix": "nx run-many --target=lint --all --fix",
    "lint:apps": "nx run-many --target=lint --projects=reBiz",
    "lint:apps:fix": "nx run-many --target=lint --projects=reBiz --fix",
    "lint:libs": "nx run-many --target=lint --projects=shared-ui",
    "lint:libs:fix": "nx run-many --target=lint --projects=shared-ui --fix",
    "format": "nx format:write",
    "format:check": "nx format:check",
    "format:apps": "nx format:write --projects=reBiz",
    "format:libs": "nx format:write --projects=shared-ui",
    "type-check": "nx run-many --target=typecheck --all",
    "type-check:apps": "nx run-many --target=typecheck --projects=reBiz",
    "clean": "nx reset && nx run-many --target=clean --all",
    "test": "nx run-many --target=test --all",
    "test:watch": "nx run-many --target=test --all --watch",
    "test:coverage": "nx run-many --target=test --all --coverage",
    "build": "nx run-many --target=build --all",
    "build:apps": "nx run-many --target=build --projects=reBiz",
    "dev": "nx serve reBiz",
    "start": "nx serve reBiz --configuration=production",
    "auth-frontend:dev": "nx serve auth-frontend",
    "auth-frontend:build": "nx build auth-frontend",
    "auth-frontend:test": "nx test auth-frontend",
    "auth-backend:dev": "nx serve auth-backend",
    "auth-backend:build": "nx build auth-backend",
    "auth-backend:test": "nx test auth-backend",
    "auth:setup-env": "node setup-auth-env.js",
    "check": "npm run format:check && npm run lint && npm run type-check",
    "check:fix": "npm run format && npm run lint:fix",
    "check:all": "npm run check && npm run test",
    "check:all:fix": "npm run check:fix && npm run test",
    "affected:build": "nx affected --target=build",
    "affected:test": "nx affected --target=test",
    "affected:lint": "nx affected --target=lint",
    "affected:type-check": "nx affected --target=typecheck",
    "graph": "nx graph",
    "dep-graph": "nx dep-graph",
    "show-projects": "nx show projects",
    "show-targets": "nx show targets",
    "migrate": "nx migrate latest",
    "reset": "nx reset"
  },
  "private": true,
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.2",
    "@mui/material": "^7.3.2",
    "@mui/system": "^7.3.2",
    "@mui/x-date-pickers": "^8.9.0",
    "@tanstack/react-query": "^5.83.0",
    "@tanstack/react-query-devtools": "^5.83.0",
    "axios": "^1.12.2",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.2",
    "express": "^4.21.2",
    "holy-loader": "^2.3.13",
    "jsonwebtoken": "^9.0.2",
    "luxon": "^3.7.1",
    "mongoose": "^8.18.2",
    "next": "~15.2.4",
    "next-auth": "^4.24.11",
    "notistack": "^3.0.2",
    "react": "~18.3.1",
    "react-dom": "~18.3.1",
    "react-is": "19.0.0",
    "react-router-dom": "^6.29.0",
    "react-spinners": "^0.17.0",
    "styled-components": "5.3.6",
    "styled-jsx": "5.1.2"
  },
  "devDependencies": {
    "@babel/core": "^7.14.5",
    "@babel/preset-react": "^7.14.5",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.8.0",
    "@nrwl/next": "^19.8.4",
    "@nrwl/react": "^19.8.4",
    "@nx/cypress": "21.2.3",
    "@nx/esbuild": "21.5.3",
    "@nx/eslint": "21.2.3",
    "@nx/eslint-plugin": "21.2.3",
    "@nx/jest": "21.2.3",
    "@nx/js": "21.5.3",
    "@nx/next": "21.4.0",
    "@nx/node": "^21.2.3",
    "@nx/react": "21.2.3",
    "@nx/vite": "21.4.0",
    "@nx/web": "21.4.0",
    "@nx/workspace": "21.2.3",
    "@swc-node/register": "~1.9.1",
    "@swc/cli": "~0.6.0",
    "@swc/core": "~1.5.7",
    "@swc/helpers": "~0.5.11",
    "@swc/jest": "~0.2.36",
    "@swc/plugin-styled-components": "^1.5.67",
    "@testing-library/dom": "10.4.0",
    "@testing-library/react": "16.1.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "20.19.9",
    "@types/react": "~18.3.12",
    "@types/react-dom": "18.3.0",
    "@types/react-is": "19.0.0",
    "@types/styled-components": "5.1.26",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/coverage-v8": "^3.0.5",
    "@vitest/ui": "^3.0.0",
    "babel-jest": "^29.7.0",
    "babel-plugin-styled-components": "1.10.7",
    "commitizen": "^4.3.1",
    "cypress": "^14.2.1",
    "cz-conventional-changelog": "^3.3.0",
    "esbuild": "^0.19.2",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-cypress": "^3.5.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.1",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "jiti": "2.4.2",
    "jsdom": "~22.1.0",
    "lint-staged": "^16.1.2",
    "nx": "21.2.3",
    "prettier": "^2.6.2",
    "react-test-renderer": "~18.3.1",
    "ts-jest": "^29.1.0",
    "ts-node": "10.9.1",
    "tslib": "^2.3.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.29.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "workspaces": [
    "apps/*",
    "reBiz",
    "shared-ui",
    "wiz-bi/*",
    "libs/shared/*",
    "libs/shared/providers",
    "libs/shared/ui-mui-theme",
    "libs/wiz-bi/ui-theme",
    "libs/wiz-bi/ui",
    "student-portal-client",
    "apps",
    "student-portal-server",
    "student-portal",
    "student-portal-backed"
  ]
}
