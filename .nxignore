# Nx ignore patterns

# Dependencies
node_modules/

# Build outputs
dist/
.next/
out/

# Cache directories
.nx/
.cache/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage/

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE files
.vscode/
.idea/
.cursor/
*.swp
*.swo
*~

# Temporary files
*.tmp
*.temp
